#!/usr/bin/env bash
set -euo pipefail

# Fail if any staged file exceeds 500 KB
echo "==> Checking for large files (>500 KB)"
git diff --cached --name-only --diff-filter=d | while read -r f; do
  kb=$(( $(wc -c < "$f") / 1024 ))
  if [ "$kb" -gt 500 ]; then
    echo "ERROR: $f is ${kb} KB (limit is 500 KB)"
    exit 1
  fi
done
echo "    ✓ No large files detected"

# Scan staged changes for secrets (if gitleaks is installed)
if command -v gitleaks &> /dev/null; then
  echo "==> Scanning for secrets with gitleaks"
  gitleaks git --pre-commit --staged --verbose
  echo "    ✓ No secrets detected"
else
  echo "==> Skipping secret scan (install gitleaks:"  \
       "https://github.com/gitleaks/gitleaks#installing)"
fi

echo "==> Running mix format --check-formatted"
mix format --check-formatted
echo "    ✓ Formatting OK"

echo "==> Running mix credo --strict"
mix credo --strict
echo "    ✓ Credo OK"

echo "==> Running mix openapi.check"
mix openapi.check
echo "    ✓ OpenAPI spec OK"

echo "==> Running mix dialyzer"
mix dialyzer
echo "    ✓ Dialyzer OK"
